---
import Layout from "@layouts/layout.astro";
import Seo from "@/components/seo.astro";
import { getJournalsSorted } from "@/lib/get-journals";
import { formatPostDate } from "@/lib/utils";

const posts = await getJournalsSorted();

const seoData = {
  title: "Dzienniki",
  description: "Codzienne notatki, ciekawostki i krótkie refleksje.",
};
console.log(posts);
---

<Layout>
  <Seo
    slot="head"
    title={seoData.title}
    description={seoData.description}
    jsonLdType="CollectionPage"
  />
  <div class="mx-auto flex w-full max-w-[50rem] flex-col gap-8">
    <header class="flex flex-col gap-3">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest">
        Today I Learned
      </p>
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Dzienniki</h1>
      <p
        class="text-foreground-body max-w-[65ch] text-lg leading-relaxed text-pretty"
      >
        Codzienne notatki, ciekawostki i krótkie refleksje.
      </p>
    </header>

    {
      posts.length > 0 ? (
        <ul class="flex flex-col gap-3 md:gap-4">
          {posts.map((post, index) => {
            const displayDate = post.data.updatedDate
              ? post.data.updatedDate
              : post.data.publishedDate;
            const formattedTime = formatPostDate(displayDate);
            const isoDate =
              displayDate instanceof Date
                ? displayDate.toISOString()
                : new Date(displayDate).toISOString();

            return (
              <li
                style={`--delay: ${Math.min(index * 60, 400)}ms`}
                class="dziennik-item"
              >
                <a
                  href={`/dzienniki/${post.id}`}
                  class="group flex items-baseline gap-3 transition-opacity duration-200"
                >
                  <time
                    datetime={isoDate}
                    class="text-foreground-secondary shrink-0 text-sm md:text-base"
                  >
                    {formattedTime}
                  </time>
                  <span class="text-foreground text-base font-medium transition-colors duration-200 group-hover:text-accent md:text-lg">
                    {post.data.title}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      ) : (
        <p class="text-foreground-secondary text-sm">Brak wpisów na razie.</p>
      )
    }
  </div>
</Layout>

<style>
  .dziennik-item {
    opacity: 0;
    transform: translateY(12px);
    animation: fadeSlideUp 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeSlideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .dziennik-item {
    transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .dziennik-item:hover {
    transform: translateX(4px);
  }
</style>
