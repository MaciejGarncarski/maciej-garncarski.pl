---
import { Picture } from "astro:assets";

import Layout from "@layouts/layout.astro";
import Seo from "@/components/seo.astro";
import Tag from "@/components/tag.astro";
import { projects } from "@/data/projects";
import AccentShimmer from "@/components/ui/accent-shimmer.astro";

const seoData = {
  title: "Projekty",
  description:
    "Przeglądaj moje najciekawsze projekty programistyczne, które pokazują moje umiejętności i pasję do tworzenia innowacyjnych rozwiązań.",
};
---

<Layout>
  <Seo slot="head" description={seoData.description} title={seoData.title} />
  <div class="mx-auto flex w-full max-w-[50rem] flex-col gap-8">
    <header class="flex flex-col gap-3">
      <p class="text-accent text-sm font-semibold uppercase tracking-widest">
        Portfolio
      </p>
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Projekty</h1>
      <p
        class="text-foreground-body max-w-[65ch] text-lg leading-relaxed text-pretty"
      >
        Najciekawsze projekty, które pokazują moje umiejętności i pasję do
        tworzenia innowacyjnych rozwiązań.
      </p>
    </header>

    <ul class="grid gap-6">
      {
        projects.map((project, idx) => {
          return (
            <li>
              <a href={`/projekty/${project.id}`} class="group block">
                <article class="project-card shadow-accent-sm bg-background-secondary/95 shadow-sm relative isolate overflow-hidden rounded-xl border border-accent/12 flex flex-col gap-5 p-5 transition-all duration-200 hover:border-accent/30 md:flex-row md:items-center md:gap-8">
                  <AccentShimmer />
                  {project.thumbnail ? (
                    <Picture
                      formats={["avif", "webp"]}
                      src={project.thumbnail}
                      alt={project.title}
                      priority={idx < 2}
                      transition:name={`project-image-${project.id}`}
                      pictureAttributes={{
                        class: "shrink-0",
                      }}
                      class="border-accent/10 w-full shrink-0 rounded-lg border object-contain md:w-56 lg:w-64"
                    />
                  ) : (
                    <div class="border-foreground/10 bg-background-secondary flex h-32 w-full shrink-0 items-center justify-center rounded-lg border md:w-56 lg:w-64">
                      <p class="text-foreground-secondary text-sm">
                        Brak podglądu
                      </p>
                    </div>
                  )}
                  <div class="flex flex-col gap-2">
                    <h2
                      class="text-xl font-semibold text-pretty group-hover:text-accent transition-colors"
                      transition:name={`project-title-${project.id}`}
                    >
                      {project.title}
                    </h2>
                    <p class="text-foreground-secondary text-sm leading-relaxed line-clamp-2">
                      {project.description}
                    </p>
                    <div class="flex flex-wrap gap-1.5 pt-1" role="list">
                      {project.tags.slice(0, 4).map((tag) => (
                        <Tag variant="small" role="listitem">
                          {tag}
                        </Tag>
                      ))}
                      {project.tags.length > 4 && (
                        <Tag variant="small">+{project.tags.length - 4}</Tag>
                      )}
                    </div>
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-foreground-secondary hidden shrink-0 transition-transform group-hover:translate-x-1 md:ml-auto md:block"
                  >
                    <path d="m9 18 6-6-6-6" />
                  </svg>
                </article>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</Layout>

<style>
  .project-card::before {
    content: "";
    position: absolute;
    inset: -50%;
    background:
      radial-gradient(
        circle at 20% 20%,
        color-mix(in oklab, var(--accent) 24%, transparent) 0%,
        transparent 38%
      ),
      radial-gradient(
        circle at 80% 30%,
        color-mix(in oklab, var(--accent) 18%, transparent) 0%,
        transparent 32%
      ),
      linear-gradient(
        120deg,
        transparent 0%,
        color-mix(in oklab, var(--accent) 30%, transparent) 45%,
        transparent 62%
      );
    background-size: 200% 200%;
    opacity: 0;
    transform: translate3d(0, 0, 0) scale(1);
    transition: opacity 400ms ease;
    pointer-events: none;
    will-change: transform, opacity;
  }

  .group:hover .project-card::before,
  .group:focus-visible .project-card::before {
    opacity: 0.35;
    animation: project-card-sheen 4s ease-in-out infinite;
  }

  @keyframes project-card-sheen {
    0%,
    100% {
      transform: translate3d(-3%, -2%, 0) scale(1);
      background-position: 0% 50%;
    }
    50% {
      transform: translate3d(3%, 2%, 0) scale(1.05);
      background-position: 100% 50%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card::before {
      animation: none !important;
      transition: opacity 240ms ease;
    }
  }
</style>
