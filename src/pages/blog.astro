---
import BlogContainer from "@components/blog/blog-container.astro";
import BlogList from "@components/blog/blog-list.astro";
import BlogSearch from "@components/blog/blog-search.astro";
import BlogTags from "@components/blog/blog-tags.astro";
import Layout from "@layouts/layout.astro";
import Seo from "@/components/seo.astro";
import { getPostsSorted } from "@/lib/get-posts-sorted";

const posts = await getPostsSorted();

const seoData = {
  title: "Blog",
  description:
    "Artykuły o architekturze systemów webowych, React, TypeScript, Node.js i praktyce pracy software engineera.",
};
---

<Layout>
  <Seo slot="head" description={seoData.description} title={seoData.title} />
  <BlogContainer>
    <BlogTags />
    <BlogSearch />
    <BlogList posts={posts} />
  </BlogContainer>
</Layout>
