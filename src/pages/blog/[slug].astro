---
import "@/styles/codeblock.css";
import "@/styles/blog.css";
import { type CollectionEntry, render } from "astro:content";
import BlogHero from "@components/blog/blog-hero.astro";
import BlogAside from "@components/blog/blog-aside.astro";
import SEO from "@components/seo.astro";
import Layout from "@layouts/layout.astro";
import { getPosts } from "@/lib/get-posts";
import BlogRelatedMobile from "@/components/blog/blog-related-mobile.astro";

export async function getStaticPaths() {
  const posts = await getPosts();

  return posts
    .filter((post) => post.data.published !== false)
    .map((post) => ({
      params: { slug: post.id },
      props: post,
    }));
}

type Props = CollectionEntry<"blog">;
const post = Astro.props;
const { Content } = await render(post);
const canonicalUrl = `/blog/${post.id}`;
const postUrl = new URL(canonicalUrl, Astro.site).toString();
const breadcrumbs = [
  { name: "Home", url: new URL("/", Astro.site).toString() },
  { name: "Blog", url: new URL("/blog", Astro.site).toString() },
  { name: post.data.title, url: postUrl },
];

const relatedProjects = post.data.relatedProjects || [];
const relatedPosts = post.data.relatedPosts || [];
---

<Layout>
  <SEO
    slot="head"
    description={post.data.description}
    title={post.data.title}
    canonicalUrl={canonicalUrl}
    publishedDate={post.data.publishedDate.toISOString()}
    updatedDate={post.data.updatedDate?.toISOString()}
    ogImage={`/blog/${post.id}/og.png`}
    category={post.data.tags?.[0]}
    tags={post.data.tags}
    breadcrumbs={breadcrumbs}
  />

  <article class="article-root flex flex-col gap-8 md:px-16">
    <div class="anim-hero">
      <BlogHero title={post.data.title} />
    </div>

    <div class="relative w-full max-w-full lg:max-w-[76ch]">
      <div class="anim-toc">
        <BlogAside
          relatedPosts={relatedPosts}
          relatedProjects={relatedProjects}
        />
      </div>

      <div
        class="anim-content motion-reduce:animation-none pb-14 text-base leading-7 text-pretty md:text-lg"
        data-blog
      >
        <Content />
      </div>

      <div class="block lg:hidden">
        <BlogRelatedMobile
          relatedProjects={relatedProjects}
          relatedPosts={relatedPosts}
        />
      </div>
    </div>
  </article>
</Layout>

<script>
  function initCopyButtons() {
    const codeBlocks = document.querySelectorAll(
      "[data-rehype-pretty-code-figure]",
    );

    codeBlocks.forEach((figure) => {
      if (figure.querySelector("[data-copy-btn]")) return;

      const isCopyIgnored = figure
        .querySelector("pre")
        ?.hasAttribute("data-ignore-copy");

      if (isCopyIgnored) {
        return;
      }

      const code = figure.querySelector("code");
      if (!code) return;

      const btn = document.createElement("button");
      btn.setAttribute("data-copy-btn", "");
      btn.setAttribute("type", "button");
      btn.setAttribute("aria-label", "Kopiuj kod");
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;

      btn.addEventListener("click", async () => {
        const text = code.textContent || "";
        await navigator.clipboard.writeText(text);

        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
        setTimeout(() => {
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
        }, 2000);
      });

      figure.appendChild(btn);
    });
  }

  initCopyButtons();
  document.addEventListener("astro:after-swap", initCopyButtons);
</script>

<style>
  @keyframes fadeSlideUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .anim-hero {
    opacity: 0;
    animation: fadeSlideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0ms forwards;
  }

  .anim-toc {
    opacity: 0;
    animation: fadeInOnly 0.35s cubic-bezier(0.22, 1, 0.36, 1) 150ms forwards;
  }

  .anim-content {
    opacity: 0;
    animation: fadeSlideUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) 220ms forwards;
  }

  @keyframes fadeInOnly {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .anim-hero,
    .anim-toc,
    .anim-content {
      opacity: 1;
      animation: none;
    }
  }
</style>
