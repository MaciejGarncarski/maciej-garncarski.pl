---
import ProjectLink from "@/components/projects/project-link.astro";
import SectionHeading from "@/components/about-page/section-heading.astro";
import Seo from "@/components/seo.astro";
import Tag from "@/components/tag.astro";
import { projects } from "@/data/projects";
import Layout from "@/layouts/layout.astro";
import { Picture } from "astro:assets";
import ChevronIcon from "@/components/ui/chevron-icon.astro";
import AccentShimmer from "@/components/ui/accent-shimmer.astro";
import { getPostsSorted } from "@/utils/get-posts-sorted";
import { normalizeTag } from "@/utils/normalize-tag";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { project: project.id },
    props: {
      project,
    },
  }));
}

const { project } = Astro.props;
const projectUrl = new URL(`/projekty/${project.id}`, Astro.site).toString();
const projectImageUrl = new URL(project.thumbnail.src, Astro.site).toString();
const breadcrumbs = [
  { name: "Home", url: new URL("/", Astro.site).toString() },
  { name: "Projekty", url: new URL("/projekty", Astro.site).toString() },
  { name: project.title, url: projectUrl },
];

const allPosts = await getPostsSorted();
const projectTagSlugs = new Set(project.tags.map((tag) => normalizeTag(tag)));
const relatedPosts = allPosts
  .filter((post) =>
    post.data.tags.some((tag) => projectTagSlugs.has(normalizeTag(tag))),
  )
  .slice(0, 3);

const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.title,
  description: project.description,
  url: projectUrl,
  image: projectImageUrl,
  keywords: project.tags,
  creator: {
    "@type": "Person",
    name: "Maciej Garncarski",
    url: "https://maciej-garncarski.pl",
  },
  codeRepository: project.github,
  sameAs: [project.github, ...(project.demo ? [project.demo] : [])],
};
---

<Layout>
  <Seo
    slot="head"
    title={project.title}
    description={project.description}
    keywords={project.tags}
    breadcrumbs={breadcrumbs}
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(projectSchema)}
  />

  <div class="mx-auto flex w-full max-w-[50rem] flex-col gap-10">
    <a
      href="/projekty"
      class="text-foreground-secondary hover:text-foreground group inline-flex w-fit items-center gap-2 text-sm transition-colors"
    >
      <ChevronIcon
        size={16}
        direction="left"
        customStyles="transition-transform group-hover:-translate-x-1"
      />
      Wróć do projektów
    </a>

    <header class="flex flex-col gap-4">
      <h1
        class="text-4xl font-bold tracking-tight md:text-5xl"
        transition:name={`project-title-${project.id}`}
      >
        {project.title}
      </h1>
      <p class="text-foreground-secondary text-lg leading-relaxed">
        {project.description}
      </p>
    </header>

    <div class="relative">
      <AccentShimmer opacity={50} />
      <Picture
        formats={["avif", "webp"]}
        layout="full-width"
        priority={true}
        src={project.thumbnail}
        alt={project.title}
        transition:name={`project-image-${project.id}`}
        class="w-full object-contain rounded-xl border border-accent/12 shadow-accent shadow-xs"
      />
    </div>
    <p class="text-foreground-secondary text-lg leading-relaxed">
      {project.descriptionSecondary}
    </p>

    <section class="flex flex-col gap-3">
      <SectionHeading title="Technologie" />
      <div class="flex flex-wrap gap-2" role="list">
        {project.tags.map((tag) => <Tag role="listitem">{tag}</Tag>)}
      </div>
    </section>

    {
      relatedPosts.length > 0 && (
        <section class="flex flex-col gap-3">
          <SectionHeading title="Powiazane artykuly" />
          <ul class="grid gap-3">
            {relatedPosts.map((post) => (
              <li>
                <a
                  href={`/blog/${post.id}`}
                  class="border-border/45 bg-background-secondary/20 hover:border-accent/30 hover:bg-background-secondary/35 block rounded-xl border p-4 transition-colors"
                >
                  <p class="text-foreground font-medium">{post.data.title}</p>
                  <p class="text-foreground-secondary mt-1 text-sm leading-relaxed">
                    {post.data.description}
                  </p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="flex flex-col gap-3">
      <SectionHeading title="Linki" />
      <div class="flex gap-4 font-semibold md:gap-6">
        {project.demo ? <ProjectLink link={project.demo} type="demo" /> : null}
        <ProjectLink link={project.github} type="repo" />
      </div>
    </section>
  </div>
</Layout>
