---
import "@/styles/codeblock.css";
import "@/styles/blog.css";
import { type CollectionEntry, render } from "astro:content";
import Layout from "@layouts/layout.astro";
import Seo from "@/components/seo.astro";
import ChevronIcon from "@/components/ui/chevron-icon.astro";
import { dateFormatter } from "@/lib/utils";
import { getJournalsSorted } from "@/lib/get-journals";

export async function getStaticPaths() {
  const entries = await getJournalsSorted();
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: entry,
  }));
}

type Props = CollectionEntry<"dzienniki">;
const entry = Astro.props;
const { Content } = await render(entry);
const canonicalUrl = `/dzienniki/${entry.id}`;
const breadcrumbs = [
  { name: "Home", url: new URL("/", Astro.site).toString() },
  { name: "Dzienniki", url: new URL("/dzienniki", Astro.site).toString() },
  { name: entry.data.title, url: new URL(canonicalUrl, Astro.site).toString() },
];

const displayDate = entry.data.updatedDate ?? entry.data.publishedDate;
const formattedDate = dateFormatter.format(new Date(displayDate));
const isoDate = new Date(displayDate).toISOString();
---

<Layout>
  <Seo
    slot="head"
    title={entry.data.title}
    description={entry.data.description}
    canonicalUrl={canonicalUrl}
    publishedDate={entry.data.publishedDate.toISOString()}
    updatedDate={entry.data.updatedDate?.toISOString()}
    breadcrumbs={breadcrumbs}
    ogImage={`/dzienniki/${entry.id}/og.png`}
  />

  <article
    class="mx-auto flex w-full flex-col gap-8 pb-8 md:max-w-[47rem] md:gap-10"
  >
    <div class="flex flex-col gap-4">
      <a
        href="/dzienniki"
        class="text-foreground-secondary hover:text-foreground group inline-flex w-fit items-center gap-2 text-sm transition-colors"
      >
        <ChevronIcon
          size={16}
          direction="left"
          customStyles="transition-transform group-hover:-translate-x-1"
        />
        Wszystkie wpisy
      </a>

      <header class="flex flex-col gap-2">
        <h1 class="text-2xl font-bold text-pretty md:text-3xl">
          {entry.data.title}
        </h1>
        <time
          datetime={isoDate}
          class="text-foreground-secondary text-sm md:text-base"
        >
          {formattedDate}
        </time>
      </header>

      <div
        class="h-px bg-linear-to-r from-accent/15 via-accent/22 to-accent/15"
      >
      </div>
    </div>

    <div class="pb-14 text-base leading-7 text-pretty md:text-lg" data-blog>
      <Content />
    </div>
  </article>
</Layout>
