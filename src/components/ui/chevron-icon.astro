---
type Props = {
  direction: "left" | "right";
  size?: number;
  customStyles?: string;
};

const { direction, size = 24, customStyles } = Astro.props;
---

{
  direction === "left" ? (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={`lucide lucide-chevron-left-icon lucide-chevron-left ${customStyles || ""}`}
    >
      <path d="m15 18-6-6 6-6" />
    </svg>
  ) : (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={`lucide lucide-chevron-right-icon lucide-chevron-right ${customStyles || ""}`}
    >
      <path d="m9 18 6-6-6-6" />
    </svg>
  )
}
