---
import logoIcon from "@assets/logoIcon.png";
import Picture from "astro/components/Picture.astro";
import clsx from "clsx";
import ThemeSwitcher from "@/components/theme-switcher.astro";

type Link = {
  url: string;
  text: string;
};

const navigationData: Array<Link> = [
  {
    text: "O mnie",
    url: "/",
  },
  {
    text: "Blog",
    url: "/blog",
  },
  {
    text: "Projekty",
    url: "/projekty",
  },
];

const baseUrl = import.meta.env.BASE_URL;
const pathname =
  baseUrl !== "/" && Astro.url.pathname.startsWith(baseUrl)
    ? `/${Astro.url.pathname.slice(baseUrl.length).replace(/^\/+/, "")}`
    : Astro.url.pathname;
const normalizedPathname =
  pathname.length > 1 && pathname.endsWith("/")
    ? pathname.slice(0, -1)
    : pathname;
const subpath = normalizedPathname.match(/[^/]+/g);
const isBlogPostPage =
  normalizedPathname.startsWith("/blog/") && normalizedPathname !== "/blog";
---

<header
  class="fixed md:sticky top-0 left-0 right-0 z-50 flex justify-center px-4 pt-4 md:pt-0 md:top-4"
>
  <div class="w-full max-w-[63rem]">
    <nav
      class="border-border/50 border-t-border/30 border-x-border/40 bg-background/90 shadow-xs relative flex items-center justify-between gap-2 overflow-hidden rounded-2xl border px-3 py-2.5 backdrop-blur-lg"
      transition:name="nav"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-linear-to-r from-transparent via-accent/5 to-transparent"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-x-8 top-0 h-px bg-linear-to-r from-transparent via-accent/18 to-transparent"
      >
      </div>

      <a href="/" class="group relative flex shrink-0 items-center gap-2.5">
        <div
          class="border-border/60 bg-background-secondary group-hover:border-accent/30 relative flex size-9 items-center justify-center overflow-hidden rounded-xl border transition-all duration-200 md:rounded-lg"
        >
          <div
            class="absolute inset-0 bg-linear-to-br from-accent/5 via-transparent to-transparent opacity-80 transition-opacity duration-200 group-hover:opacity-100"
          >
          </div>
          <Picture
            formats={["avif", "webp"]}
            src={logoIcon}
            alt="Maciej Garncarski Logo"
            height={36}
            width={36}
            priority={true}
            class="relative size-9 transition-transform duration-300 group-hover:scale-105 group-active:scale-97"
          />
        </div>
      </a>

      <ul
        class="relative hidden items-center gap-6 md:flex"
        transition:name="nav-menu"
      >
        {
          navigationData.map((n) => {
            const isActive =
              n.url === normalizedPathname ||
              n.url === "/" + (subpath?.[0] || "");
            const isBlogPage = n.url === "/blog";
            const isBlogPageActive =
              isBlogPage && /^\/blog(?:\/|$)/.test(normalizedPathname);
            const active = isActive || isBlogPageActive;

            return (
              <li>
                <a
                  href={n.url}
                  class={clsx(
                    "relative rounded-xl px-4 py-2 text-sm font-medium transition-all duration-200",
                    active
                      ? "bg-accent/10 text-foreground"
                      : "text-foreground-secondary hover:bg-accent/5 hover:text-foreground",
                  )}
                >
                  {n.text}
                  {active && (
                    <span class="bg-accent absolute bottom-1 left-1/2 h-0.5 w-4 -translate-x-1/2 rounded-full opacity-80" />
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>

      <div class="relative flex items-center gap-3">
        <ThemeSwitcher />

        <button
          data-mobile-menu-toggle
          aria-label="Menu nawigacyjne"
          aria-expanded="false"
          class="border-border/60 bg-background-secondary hover:bg-foreground/8 flex size-9 cursor-pointer items-center justify-center rounded-xl border transition-colors duration-200 md:hidden"
        >
          <svg
            data-icon-menu
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-all duration-200"
          >
            <line x1="4" y1="8" x2="20" y2="8"></line>
            <line x1="4" y1="16" x2="14" y2="16"></line>
          </svg>
          <svg
            data-icon-close
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden transition-all duration-200"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      {
        isBlogPostPage && (
          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 h-[2px] rounded-full overflow-hidden">
            <div
              data-nav-scroll-indicator
              class="h-full origin-left bg-linear-to-r from-accent/15 via-accent/45 to-accent/50 transition-[transform] duration-100 ease-out"
            />
          </div>
        )
      }
    </nav>

    <div
      data-mobile-menu
      class="pointer-events-none mt-1.5 grid grid-rows-[0fr] transition-[grid-template-rows] duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] md:hidden"
    >
      <div class="overflow-hidden">
        <div
          data-mobile-menu-panel
          class="relative overflow-hidden rounded-2xl transition-transform duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform"
          style="transform: translateY(-0.6rem) scale(0.985);"
        >
          <div
            class="border-border/50 bg-background/90 absolute inset-0 rounded-2xl border backdrop-blur-lg"
          >
          </div>
          <div
            class="pointer-events-none absolute inset-0 bg-linear-to-r from-transparent via-accent/5 to-transparent"
          >
          </div>
          <ul class="relative flex flex-col gap-0.5 p-2">
            {
              navigationData.map((n, index) => {
                const isActive =
                  n.url === normalizedPathname ||
                  n.url === "/" + (subpath?.[0] || "");
                const isBlogPage = n.url === "/blog";
                const isBlogPageActive =
                  isBlogPage && /^\/blog(?:\/|$)/.test(normalizedPathname);
                const active = isActive || isBlogPageActive;

                return (
                  <li>
                    <a
                      href={n.url}
                      data-mobile-menu-item
                      style={`--item-index: ${index}; opacity: 0; transform: translateY(-0.35rem);`}
                      class={clsx(
                        "flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-[transform,opacity,background-color,color] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]",
                        active
                          ? "bg-accent/10 text-foreground"
                          : "text-foreground-secondary hover:bg-accent/8 hover:text-foreground",
                      )}
                    >
                      {active && (
                        <span class="bg-accent size-1.5 shrink-0 rounded-full" />
                      )}
                      {!active && (
                        <span class="size-1.5 shrink-0 rounded-full" />
                      )}
                      {n.text}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </div>
      </div>
    </div>
  </div>
</header>

<div class="h-16 md:hidden"></div>

<script>
  declare global {
    interface Window {
      __cleanupNavigationMenu?: () => void;
    }
  }

  function setupMobileMenu() {
    window.__cleanupNavigationMenu?.();

    const controller = new AbortController();
    const { signal } = controller;

    const scrollIndicator = document.querySelector(
      "[data-nav-scroll-indicator]",
    ) as HTMLElement | null;

    let ticking = false;

    function updateScrollIndicator() {
      if (!scrollIndicator) return;

      const maxScroll =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;

      const progress =
        maxScroll > 0
          ? Math.min(Math.max(window.scrollY / maxScroll, 0), 1)
          : 0;

      scrollIndicator.style.transform = `scaleX(${progress})`;
    }

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateScrollIndicator();
          ticking = false;
        });
        ticking = true;
      }
    }

    if (scrollIndicator) {
      updateScrollIndicator();
      window.addEventListener("scroll", onScroll, {
        passive: true,
        signal,
      });
      window.addEventListener("resize", onScroll, { signal });
    }

    const toggle = document.querySelector(
      "[data-mobile-menu-toggle]",
    ) as HTMLButtonElement | null;
    const menu = document.querySelector(
      "[data-mobile-menu]",
    ) as HTMLElement | null;
    const panel = document.querySelector(
      "[data-mobile-menu-panel]",
    ) as HTMLElement | null;
    const items = Array.from(
      document.querySelectorAll("[data-mobile-menu-item]"),
    ) as HTMLElement[];
    const iconMenu = document.querySelector(
      "[data-icon-menu]",
    ) as SVGElement | null;
    const iconClose = document.querySelector(
      "[data-icon-close]",
    ) as SVGElement | null;

    if (!toggle || !menu || !panel || !iconMenu || !iconClose) {
      window.__cleanupNavigationMenu = () => controller.abort();
      return;
    }

    let isOpen = false;

    function updateItems(open: boolean) {
      items.forEach((item, index) => {
        item.style.transitionDelay = open ? `${70 + index * 38}ms` : "0ms";
        item.style.opacity = open ? "1" : "0";
        item.style.transform = open ? "translateY(0)" : "translateY(-0.35rem)";
      });
    }

    function setOpen(open: boolean) {
      isOpen = open;
      toggle?.setAttribute("aria-expanded", String(open));

      if (!menu || !panel || !iconMenu || !iconClose) return;

      if (open) {
        menu.style.gridTemplateRows = "1fr";
        menu.classList.remove("pointer-events-none");
        panel.style.transform = "translateY(0) scale(1)";
        iconMenu.classList.add("hidden");
        iconClose.classList.remove("hidden");
        updateItems(true);
      } else {
        updateItems(false);
        panel.style.transform = "translateY(-0.6rem) scale(0.985)";
        menu.style.gridTemplateRows = "0fr";
        menu.classList.add("pointer-events-none");
        iconMenu.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    }

    toggle.addEventListener("click", () => setOpen(!isOpen), { signal });

    document.addEventListener(
      "click",
      (e) => {
        if (
          isOpen &&
          !toggle.contains(e.target as Node) &&
          !menu.contains(e.target as Node)
        ) {
          setOpen(false);
        }
      },
      { signal },
    );

    document.addEventListener(
      "keydown",
      (e) => {
        if (e.key === "Escape" && isOpen) {
          setOpen(false);
          toggle.focus();
        }
      },
      { signal },
    );

    items.forEach((item) => {
      item.addEventListener("click", () => setOpen(false), { signal });
    });

    window.__cleanupNavigationMenu = () => controller.abort();
  }

  setupMobileMenu();

  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
