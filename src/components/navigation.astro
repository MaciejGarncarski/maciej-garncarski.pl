---
import logoIcon from "@assets/logoIcon.png";
import Picture from "astro/components/Picture.astro";
import clsx from "clsx";
import ThemeSwitcher from "@/components/theme-switcher.astro";

type Link = {
  url: string;
  text: string;
};

const navigationData: Array<Link> = [
  {
    text: "O mnie",
    url: "/",
  },
  {
    text: "Blog",
    url: "/blog",
  },
  {
    text: "Projekty",
    url: "/projekty",
  },
];

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, "");
const subpath = pathname.match(/[^/]+/g);
---

<header
  class="fixed top-2 md:top-4 left-0 right-0 z-50 flex justify-center px-4 pt-4 md:pt-5"
>
  <div class="w-full max-w-[63rem]">
    <nav
      class="border-border/50 bg-background/90 backdrop-blur-lg shadow-xs flex items-center justify-between gap-2 rounded-2xl border px-3 py-2"
      transition:name="nav"
    >
      <!-- Logo -->
      <a href="/" class="group flex shrink-0 items-center gap-2.5">
        <div
          class="border-border/60 bg-background-secondary group-hover:border-accent/40 relative flex size-9 items-center justify-center overflow-hidden rounded-xl md:rounded-lg border transition-all duration-200"
        >
          <Picture
            formats={["webp"]}
            src={logoIcon}
            alt="Maciej Garncarski Logo"
            height={36}
            width={36}
            priority={true}
            class="size-9 transition-transform duration-300 group-hover:scale-110"
          />
        </div>
      </a>

      <!-- Desktop links -->
      <ul class="hidden items-center gap-6 md:flex" transition:name="nav-menu">
        {
          navigationData.map((n) => {
            const isActive =
              n.url === pathname || n.url === "/" + (subpath?.[0] || "");
            const isBlogPage = n.url === "/blog/";
            const isBlogPageActive =
              isBlogPage && Astro.url.pathname.startsWith("/blog/");
            const active = isActive || isBlogPageActive;

            return (
              <li>
                <a
                  href={n.url}
                  class={clsx(
                    "relative rounded-xl px-4 py-2 text-sm font-medium transition-all duration-200",
                    active
                      ? "text-foreground bg-accent/10"
                      : "text-foreground-secondary hover:text-foreground hover:bg-accent/5",
                  )}
                >
                  {n.text}
                  {active && (
                    <span class="bg-accent absolute bottom-1 left-1/2 h-0.5 w-4 -translate-x-1/2 rounded-full opacity-80" />
                  )}
                </a>
              </li>
            );
          })
        }
      </ul>

      <!-- Right side: theme switcher + mobile toggle -->
      <div class="flex items-center gap-1.5">
        <ThemeSwitcher />

        <button
          data-mobile-menu-toggle
          aria-label="Menu nawigacyjne"
          aria-expanded="false"
          class="border-border/60 bg-background-secondary hover:bg-foreground/8 flex size-9 cursor-pointer items-center justify-center rounded-xl border transition-colors duration-200 md:hidden"
        >
          <svg
            data-icon-menu
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-all duration-200"
          >
            <line x1="4" y1="8" x2="20" y2="8"></line>
            <line x1="4" y1="16" x2="14" y2="16"></line>
          </svg>
          <svg
            data-icon-close
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden transition-all duration-200"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div
      data-mobile-menu
      class="pointer-events-none mt-1.5 grid grid-rows-[0fr] transition-all duration-300 ease-out md:hidden"
      style="opacity: 0;"
    >
      <div class="overflow-hidden">
        <ul
          class="border-border/50 bg-background/90 backdrop-blur-lg flex flex-col gap-0.5 rounded-2xl border p-2"
        >
          {
            navigationData.map((n) => {
              const isActive =
                n.url === pathname || n.url === "/" + (subpath?.[0] || "");
              const isBlogPage = n.url === "/blog/";
              const isBlogPageActive =
                isBlogPage && Astro.url.pathname.startsWith("/blog/");
              const active = isActive || isBlogPageActive;

              return (
                <li>
                  <a
                    href={n.url}
                    class={clsx(
                      "flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition-all duration-150",
                      active
                        ? "bg-accent/10 text-foreground"
                        : "text-foreground-secondary hover:bg-accent/8 hover:text-foreground",
                    )}
                  >
                    {active && (
                      <span class="bg-accent size-1.5 shrink-0 rounded-full" />
                    )}
                    {!active && <span class="size-1.5 shrink-0 rounded-full" />}
                    {n.text}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </div>
    </div>
  </div>
</header>

<!-- Spacer -->
<div class="h-12 md:h-12"></div>

<script>
  function setupMobileMenu() {
    const toggle = document.querySelector(
      "[data-mobile-menu-toggle]",
    ) as HTMLButtonElement | null;
    const menu = document.querySelector(
      "[data-mobile-menu]",
    ) as HTMLElement | null;
    const iconMenu = document.querySelector(
      "[data-icon-menu]",
    ) as SVGElement | null;
    const iconClose = document.querySelector(
      "[data-icon-close]",
    ) as SVGElement | null;

    if (!toggle || !menu || !iconMenu || !iconClose) return;

    let isOpen = false;

    function setOpen(open: boolean) {
      isOpen = open;
      toggle?.setAttribute("aria-expanded", String(open));

      if (!menu || !iconMenu || !iconClose) return;

      if (open) {
        menu.style.opacity = "1";
        menu.style.gridTemplateRows = "1fr";
        menu.classList.remove("pointer-events-none");
        iconMenu.classList.add("hidden");
        iconClose.classList.remove("hidden");
      } else {
        menu.style.opacity = "0";
        menu.style.gridTemplateRows = "0fr";
        menu.classList.add("pointer-events-none");
        iconMenu.classList.remove("hidden");
        iconClose.classList.add("hidden");
      }
    }

    toggle.addEventListener("click", () => setOpen(!isOpen));

    document.addEventListener("click", (e) => {
      if (
        isOpen &&
        !toggle.contains(e.target as Node) &&
        !menu.contains(e.target as Node)
      ) {
        setOpen(false);
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        setOpen(false);
        toggle.focus();
      }
    });
  }

  setupMobileMenu();

  document.addEventListener("astro:after-swap", setupMobileMenu);
</script>
