---
import BlogItem from "@/components/blog/blog-item.astro";
import { formatPostDate } from "@/utils/format-post-date";

type Props = {
  posts: Array<{
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      updatedDate?: Date;
      heroImage: ImageMetadata;
    };
  }>;
};
const { posts } = Astro.props;
---

<div class="grid gap-6 px-1 md:px-0 md:gap-0">
  {
    posts.map((post) => {
      const formattedTime = formatPostDate(
        post.data.updatedDate ? post.data.updatedDate : post.data.pubDate,
      );

      return <BlogItem post={post} formattedTime={formattedTime} />;
    })
  }
</div>
