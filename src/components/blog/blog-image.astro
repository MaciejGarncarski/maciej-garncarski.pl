---
import { Picture } from "astro:assets";

type Props = {
  src: ImageMetadata;
  alt: string;
  caption?: string;
};

const props = Astro.props;
---

<figure>
  <Picture data-blog-img src={props.src} alt={props.alt} />
  {props.caption && <figcaption data-figcaption>{props.caption}</figcaption>}
</figure>
