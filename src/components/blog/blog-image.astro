---
import { Picture } from "astro:assets";

type Props = {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  withPadding?: boolean;
  withSolidBackground?: boolean;
};

const props = Astro.props;
---

<figure
  data-with-padding={props.withPadding}
  data-with-solid-background={props.withSolidBackground}
>
  <Picture
    formats={["avif", "webp"]}
    data-blog-img
    src={props.src}
    alt={props.alt}
  />
  {props.caption && <figcaption data-figcaption>{props.caption}</figcaption>}
</figure>
