---
import { calculateReadingTime } from "@utils/calculate-read-time";
import { getPosts } from "@/utils/get-posts";
import { normalizeTag } from "@/utils/normalize-tag";
import Tag from "@/components/tag.astro";
import ChevronIcon from "@/components/ui/chevron-icon.astro";
import clsx from "clsx";

type Props = {
  title: string;
};

const { title } = Astro.props;

const allBlogPosts = await getPosts();
const currPost = allBlogPosts.find((post) => post.data.title === title);
const readTime = calculateReadingTime(currPost?.body || "");
const words = currPost?.body ? currPost.body.split(/\s+/).length : 0;

const publishDate = new Intl.DateTimeFormat("pl-PL", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(
  currPost?.data.pubDate ? new Date(currPost.data.pubDate) : new Date(),
);

const updateDate = currPost?.data.updatedDate
  ? new Intl.DateTimeFormat("pl-PL", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(new Date(currPost.data.updatedDate))
  : null;

const tags = currPost?.data.tags || [];

const sortedTags = tags.sort((a, b) =>
  a.localeCompare(b, undefined, { sensitivity: "base" }),
);

const isShortTitle = title.length <= 40;
const isMediumTitle = title.length > 40 && title.length <= 65;

const lastModifiedDateString = new Date(
  currPost?.data.updatedDate || currPost?.data.pubDate || new Date(),
).toISOString();

const lastModified = updateDate ? updateDate : publishDate;
---

<div class="lg:w-[85ch]">
  <a
    id="back-link"
    href="/blog"
    class="text-foreground-secondary hover:text-foreground group inline-flex w-fit items-center mb-6 gap-2 text-sm transition-colors"
  >
    <ChevronIcon
      size={16}
      direction="left"
      customStyles="transition-transform group-hover:-translate-x-1"
    />
    Inne posty
  </a>
</div>

<header class="relative flex w-full flex-col gap-6">
  <div class="flex lg:flex-row flex-col gap-6 lg:gap-12 xl:gap-16">
    <div class="flex flex-1 flex-col gap-4 md:gap-6">
      <h1
        class={clsx(
          "text-2xl leading-tight font-bold text-pretty md:text-3xl",
          {
            "lg:text-4xl": isMediumTitle || isShortTitle,
            "lg:text-3xl": !isShortTitle && !isMediumTitle,
          },
        )}
      >
        {title}
      </h1>

      <div
        class="text-foreground-secondary flex flex-wrap items-center gap-x-2 gap-y-1 text-sm md:text-base"
      >
        <time itemprop="datePublished" datetime={lastModifiedDateString}>
          Ostatnia zmiana: {lastModified}
        </time>
        <span class="text-accent">&bull;</span>
        <span>{readTime} min. czytania</span>
        <span class="text-accent">&bull;</span>
        <span>{words} słów</span>
      </div>
    </div>
    {
      sortedTags.length > 0 && (
        <div class="flex flex-wrap items-center gap-1.5 md:gap-x-3 md:gap-y-0 lg:max-w-[33%] lg:items-end lg:justify-end">
          {sortedTags.map((tag) => (
            <Tag href={`/blog/tag/${normalizeTag(tag)}`}># {tag}</Tag>
          ))}
        </div>
      )
    }
  </div>

  <div
    class="w-full h-px bg-linear-to-r from-accent/15 via-accent/22 to-accent/15"
  >
  </div>
</header>

<script>
  function initLink() {
    const backLink = document.getElementById("back-link");
    if (!backLink) return;

    backLink.onclick = (e) => {
      const referrer = document.referrer;
      let isSameOrigin = false;
      let referrerPathname = "";

      try {
        if (referrer) {
          const referrerUrl = new URL(referrer);
          isSameOrigin = referrerUrl.origin === window.location.origin;
          referrerPathname = referrerUrl.pathname;
        }
      } catch (err) {}

      if (isSameOrigin) {
        e.preventDefault();

        if (referrerPathname === "/") {
          window.location.href = "/blog";
        } else {
          history.back();
        }
      }
    };
  }

  document.addEventListener("DOMContentLoaded", initLink);
  document.addEventListener("astro:after-swap", initLink);
</script>
