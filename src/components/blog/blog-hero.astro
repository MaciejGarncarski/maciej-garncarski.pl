---
import { Image } from "astro:assets";
import { fade } from "astro:transitions";
import { calculateReadingTime } from "@utils/calculate-read-time";
import { getPosts } from "@/utils/get-posts";
import { normalizeTag } from "@/utils/normalize-tag";
import Tag from "@/components/tag.astro";
import ChevronIcon from "@/components/ui/chevron-icon.astro";

type Props = {
  text: string;
};

const { text } = Astro.props;

const allBlogPosts = await getPosts();
const currPost = allBlogPosts.find((post) => post.data.title === text);
const readTime = calculateReadingTime(currPost?.body || "");
const words = currPost?.body ? currPost.body.split(/\s+/).length : 0;

const publishDate = new Intl.DateTimeFormat("pl-PL", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(
  currPost?.data.pubDate ? new Date(currPost.data.pubDate) : new Date(),
);

const updateDate = currPost?.data.updatedDate
  ? new Intl.DateTimeFormat("pl-PL", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }).format(new Date(currPost.data.updatedDate))
  : null;

const tags = currPost?.data.tags || [];

const sortedTags = tags.sort((a, b) =>
  a.localeCompare(b, undefined, { sensitivity: "base" }),
);
---

<a
  id="back-link"
  href="/blog"
  class="text-foreground-secondary md:ml-48 mx-none hover:text-foreground group inline-flex w-fit items-center gap-2 text-sm transition-colors"
>
  <ChevronIcon
    size={16}
    direction="left"
    customStyles="transition-transform group-hover:-translate-x-1"
  />
  Inne posty
</a>

<script>
  function initLink() {
    const backLink = document.getElementById("back-link");
    if (!backLink) return;

    backLink.onclick = (e) => {
      const referrer = document.referrer;
      let isSameOrigin = false;

      try {
        if (referrer) {
          isSameOrigin = new URL(referrer).origin === window.location.origin;
        }
      } catch {}

      if (isSameOrigin) {
        e.preventDefault();
        history.back();
      }
    };
  }

  document.addEventListener("DOMContentLoaded", initLink);
  document.addEventListener("astro:after-swap", initLink);
</script>

<header class="relative mx-auto flex w-full max-w-[85ch] flex-col gap-6">
  <div class="flex flex-col gap-6 md:flex-row-reverse md:items-start md:gap-8">
    {
      currPost?.data.heroImage && currPost.id && (
        <Image
          src={currPost.data.heroImage}
          transition:name={`blog-image-${currPost.id}`}
          transition:animate={fade({ duration: "0.3s" })}
          width={400}
          height={400}
          alt={""}
          class="aspect-square mx-auto shrink-0 rounded-xl object-cover shadow-lg md:w-44"
          priority={true}
        />
      )
    }

    <div
      class="flex flex-1 flex-col gap-4"
      transition:name={`blog-header-${currPost?.id}`}
    >
      <h1
        class="max-w-[40rem] text-2xl leading-tight font-bold text-balance md:text-3xl lg:text-4xl"
      >
        {text}
      </h1>

      <div
        class="text-foreground-secondary flex flex-wrap items-center gap-x-2 gap-y-1 text-sm"
      >
        <time
          itemprop="datePublished"
          datetime={new Date(currPost?.data.pubDate || "").toISOString()}
        >
          {publishDate}
        </time>

        {
          currPost?.data.updatedDate && (
            <>
              <span class="text-accent">&middot;</span>
              <time
                itemprop="dateModified"
                datetime={new Date(currPost.data.updatedDate).toISOString()}
              >
                aktualizacja {updateDate}
              </time>
            </>
          )
        }

        <span class="text-accent">&middot;</span>
        <span>{readTime} min. czytania</span>
        <span class="text-accent">&middot;</span>
        <span>{words} słów</span>
      </div>

      {
        sortedTags.length > 0 && (
          <div class="flex flex-wrap items-center gap-1.5 pt-1">
            {sortedTags.map((tag) => (
              <Tag href={`/blog/tag/${normalizeTag(tag)}`}># {tag}</Tag>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <hr class="border-border/50" />
</header>
