---
import { projectsDict } from "@/data/projects";
import { getPosts } from "@/lib/get-posts";
import AccentShimmer from "../ui/accent-shimmer.astro";

type Props = {
    relatedProjects?: string[];
    relatedPosts?: string[];
};

const posts = await getPosts();
const postsDict = new Map(posts.map((post) => [post.id, post]));

const relatedProjects = Astro.props.relatedProjects || [];
const relatedPosts = Astro.props.relatedPosts || [];

const isEmpty = relatedProjects.length === 0 && relatedPosts.length === 0;
---

{
    isEmpty ? null : (
        <section
            class="anim-related relative border-border/40 flex flex-col gap-3 bg-background-secondary/20 rounded-2xl border p-4"
            aria-labelledby="powiazane"
        >
            <AccentShimmer />
            <h2
                id="powiazane"
                class="text-foreground text-xl font-semibold md:text-2xl"
            >
                Powiązane treści
            </h2>

            <div class="flex gap-6 flex-col">
                {relatedPosts.length > 0 && (
                    <div class="flex flex-col gap-3">
                        <p class="text-foreground-secondary text-sm md:text-base">
                            Inne wpisy na blogu, które mogą Cię zainteresować.
                        </p>
                        <ul class=" grid gap-3">
                            {relatedPosts.map((post, i) => {
                                const postData = postsDict.get(post);

                                if (!postData) {
                                    throw new Error(
                                        `Post with id "${post}" not found in postsDict.`,
                                    );
                                }

                                return (
                                    <li
                                        style={`--i: ${i}`}
                                        class="related-item"
                                    >
                                        <a
                                            href={`/blog/${postData.id}`}
                                            class="border-border/45 bg-background hover:border-accent/30 hover:bg-background-secondary/50 block rounded-xl border p-4 transition-colors"
                                        >
                                            <p class="text-foreground font-medium">
                                                {postData.data.title}
                                            </p>
                                            <p class="text-foreground-secondary mt-1 text-sm leading-relaxed">
                                                {postData.data.description}
                                            </p>
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    </div>
                )}

                {relatedProjects.length > 0 && (
                    <div class="flex flex-col gap-3">
                        <p class="text-foreground-secondary text-sm md:text-base">
                            Projekty, które rozwijają podobne tematy.
                        </p>
                        <ul class=" grid gap-3">
                            {relatedProjects.map((project, i) => {
                                const projectData = projectsDict[project];

                                if (!projectData) {
                                    return null;
                                }

                                return (
                                    <li
                                        style={`--i: ${i}`}
                                        class="related-item"
                                    >
                                        <a
                                            href={`/projekty/${projectData.id}`}
                                            class="border-border/45 bg-background hover:border-accent/30 hover:bg-background-secondary/50 block rounded-xl border p-4 transition-colors"
                                        >
                                            <p class="text-foreground font-medium">
                                                {projectData.title}
                                            </p>
                                            <p class="text-foreground-secondary mt-1 text-sm leading-relaxed">
                                                {projectData.description}
                                            </p>
                                        </a>
                                    </li>
                                );
                            })}
                        </ul>
                    </div>
                )}
            </div>
        </section>
    )
}
