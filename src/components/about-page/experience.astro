---
import SectionHeading from "@/components/about-page/section-heading.astro";
import AccentShimmer from "@/components/ui/accent-shimmer.astro";
import Tag from "../tag.astro";

type Highlight = {
  title: string;
  description: string;
  tags?: string[];
};

type Experience = {
  period: string;
  company: string;
  role: string;
  highlights: Highlight[];
};

function capitalize(str: string) {
  return str.charAt(0).toUpperCase() + str.slice(1);
}

const experiences: Experience[] = [
  {
    period: "lis. 2023 — obecnie",
    company: "Kokscraft",
    role: "Full Stack Developer",
    highlights: [
      {
        title: "System Kontroli Dostępu (RBAC)",
        description:
          "Granularny system uprawnień zwiększający bezpieczeństwo danych i precyzję zarządzania rolami użytkowników.",
        tags: ["Node.js", "MySQL"],
      },
      {
        title: "Komunikacja Real-time",
        description:
          "Moduły oparte o WebSockets umożliwiające monitorowanie aktywności w czasie rzeczywistym przy minimalnym opóźnieniu.",
        tags: ["WebSockets"],
      },
      {
        title: "Zaawansowany UI/UX",
        description:
          "Responsywny frontend z komponentami Data Grid, filtrowaniem po stronie serwera i optymalizacją renderowania.",
        tags: ["React", "TypeScript"],
      },
      {
        title: "Audyt i Logi",
        description:
          "System logowania zdarzeń zapewniający transparentność działań administratorów i historyczność zmian.",
        tags: ["Prisma"],
      },
      {
        title: "Zarządzanie Danymi",
        description:
          "Optymalizacja zapytań i schematów bazodanowych pod dużym obciążeniem.",
        tags: ["Prisma", "MySQL"],
      },
      {
        title: "Maintenance & Security",
        description:
          "Utrzymanie długu technicznego, automatyzacja aktualizacji zależności i spójność architektury.",
      },
    ],
  },
];
---

<section class="flex flex-col gap-6" aria-labelledby="doswiadczenie">
  <SectionHeading title="Doświadczenie" id="doswiadczenie" />
  {
    experiences.map((exp) => (
      <div class="flex flex-col gap-4 md:flex-row md:gap-10">
        <div class="flex shrink-0 flex-col gap-1 md:w-28 md:pt-1">
          <p class="text-[0.8125rem] font-semibold leading-snug">
            {exp.company}
          </p>
          <p class="text-foreground-secondary text-[0.6875rem] uppercase tracking-[0.1em]">
            {exp.period}
          </p>
        </div>

        <div class="flex flex-col gap-4">
          <h3 class="text-lg font-semibold">{exp.role}</h3>
          <div class="grid gap-2.5 sm:grid-cols-2 sm:auto-rows-fr">
            {exp.highlights.map(({ title, description, tags }) => (
              <div class="border-border/50 relative flex flex-col gap-1.5 rounded-md border bg-background-secondary/30 px-3.5 py-3">
                <AccentShimmer opacity={20} />
                <span class="text-[0.8125rem] font-semibold text-foreground">
                  {title}
                </span>
                <span class="text-foreground-body text-[0.8125rem] leading-relaxed text-pretty flex-1">
                  {capitalize(description)}
                </span>
                {tags && tags.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-1">
                    {tags.map((tag) => (
                      <Tag variant="small">{tag}</Tag>
                    ))}
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    ))
  }
</section>
