---
import SectionHeading from "@/components/about-page/section-heading.astro";
import { groups } from "@/data/technologies";
import clsx from "clsx";
---

<section class="flex flex-col gap-6">
  <SectionHeading title="Technologie" />
  <div class="flex flex-col">
    {
      groups.map(({ label, techs }, groupIndex) => (
        <div
          class={clsx(
            "flex flex-col gap-3 py-5 md:flex-row md:gap-10",
            groupIndex !== 0 && "border-t border-border/50",
            groupIndex === 0 && "pt-0",
            groupIndex === groups.length - 1 && "pb-0",
          )}
        >
          <h3 class="shrink-0 text-[0.6875rem] font-semibold uppercase tracking-[0.15em] text-foreground-secondary md:w-28 md:pt-2">
            {label}
          </h3>
          <ul class="flex flex-wrap gap-1.5">
            {techs.map(
              ({ color, iconColor, darkIconColor, icon: Icon, name, link }) => {
                const techColor = color === "#000000" ? "var(--accent)" : color;
                const techIconColor =
                  color === "#000000"
                    ? "var(--foreground-secondary)"
                    : iconColor;
                const techIconColorDark = darkIconColor ?? techIconColor;

                return (
                  <li>
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener noreferrer"
                      style={`--tech-color: ${techColor}; --tech-icon: ${techIconColor}; --tech-icon-dark: ${techIconColorDark}`}
                      class="group inline-flex items-center gap-2 rounded-full border border-border/70 bg-background-secondary/40 px-3 py-1.5 text-[0.8125rem] font-medium outline-none transition-all duration-200 ease-out hover:border-(--tech-color)/30 hover:bg-(--tech-color)/10 focus-visible:ring-2 focus-visible:ring-accent/40 dark:border-border dark:hover:border-(--tech-color)/35 dark:hover:bg-(--tech-color)/15"
                    >
                      <span class="flex size-4 shrink-0 items-center [&>svg]:size-4 text-(--tech-icon) dark:text-(--tech-icon-dark) transition-transform duration-200 group-hover:scale-110">
                        <Icon />
                      </span>
                      <span class="text-foreground-body transition-colors duration-200 group-hover:text-foreground">
                        {name}
                      </span>
                    </a>
                  </li>
                );
              },
            )}
          </ul>
        </div>
      ))
    }
  </div>
</section>
