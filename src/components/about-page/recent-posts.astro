---
import SectionHeading from "@/components/about-page/section-heading.astro";
import AccentShimmer from "@/components/ui/accent-shimmer.astro";
import { formatPostDate } from "@/lib/utils";
import { getPostsSorted } from "@/lib/get-posts-sorted";

const allBlogPosts = await getPostsSorted();
const recentPosts = allBlogPosts.slice(0, 3);
---

<section class="flex flex-col gap-6" aria-labelledby="ostatnie-posty">
  <SectionHeading title="Ostatnie posty" id="ostatnie-posty" />

  <div class="grid gap-4 md:gap-6">
    {
      recentPosts.map((post) => {
        const slug = post.id;
        const { title, description, publishedDate, updatedDate } = post.data;
        const date = formatPostDate(updatedDate ? updatedDate : publishedDate);

        return (
          <a
            class="shadow-accent-sm bg-background-secondary/30 backdrop-blur-xs border-border relative hover:border-accent/16 group flex flex-col gap-3 rounded-lg border p-4 transition-colors sm:p-5"
            href={`/blog/${slug}`}
          >
            <AccentShimmer opacity={25} />
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
              <h3 class="text-base font-semibold group-hover:text-accent transition-colors sm:text-lg">
                {title}
              </h3>
              <span class="text-foreground-secondary text-xs font-medium tabular-nums sm:ml-auto sm:text-sm">
                {date}
              </span>
            </div>
            <p class="text-foreground-body max-w-[65ch] text-[0.938rem] leading-relaxed text-pretty">
              {description}
            </p>
          </a>
        );
      })
    }
  </div>
</section>
