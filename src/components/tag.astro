---
import clsx from "clsx";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"span"> & {
  /**
   * "default" — standard display tag (blog hero, project detail)
   * "filter" — interactive filter with active/inactive states (blog tag list)
   * "small" — compact tag for cards (project listing)
   * "search" — micro tag for modal search results
   */
  variant?: "default" | "filter" | "small" | "search";
  active?: boolean;
  href?: string;
};

const {
  variant = "default",
  active = false,
  href,
  class: className,
  ...rest
} = Astro.props;

const isLink = !!href;
const Element = isLink ? "a" : "span";

const sizeClasses = {
  default: "px-3 py-1 text-sm",
  filter: "px-3 py-1 text-sm",
  small: "px-2.5 py-0.5 text-xs",
  search: "px-2 py-0.5 text-[11px]",
} as const;

const variantClasses = {
  default:
    "border border-accent/10 bg-accent/15 text-foreground/80 hover:bg-accent/25 focus:bg-accent/25",
  filter: active
    ? "border border-accent/10 bg-accent/40 text-foreground"
    : "border border-accent/7 bg-accent/8 text-foreground/80 hover:bg-accent/30 focus:bg-accent/30",
  small: "bg-accent/15 text-foreground/70",
  search:
    "border border-border bg-accent/9 text-foreground-secondary transition-colors duration-200",
} as const;
---

<Element
  href={isLink ? href : undefined}
  class={clsx(
    "inline-flex items-center justify-center rounded-full font-medium motion-reduce:transition-none transition-colors duration-300",
    sizeClasses[variant],
    variantClasses[variant],
    className,
  )}
  {...rest}
>
  <slot />
</Element>
