---
import "@/styles/global.css";
import { Font } from "astro:assets";
import SEO from "@components/seo.astro";

type Props = {
  faviconScript?: "default" | "rerun";
};

const { faviconScript = "default" } = Astro.props;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />

<slot name="head">
  <SEO />
</slot>

<link rel="sitemap" href="/sitemap-index.xml" />
<Font cssVariable="--font-ui" preload />

<link rel="icon" href="/favicon.ico" sizes="48x48" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<link rel="icon" type="image/png" data-theme-favicon />

<script is:inline>
  const stored = localStorage.getItem("theme");
  const theme =
    stored === "light" || stored === "dark"
      ? stored
      : window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light";
  document.documentElement.className = theme;
</script>

{
  faviconScript === "default" && (
    <script is:inline>
      (() => {
        const systemThemeQuery = window.matchMedia(
          "(prefers-color-scheme: dark)",
        );

        const faviconLightMode = "/favicon-light-theme.png";
        const faviconDarkMode = "/favicon-dark-theme.png";

        function getCurrentTheme() {
          const stored = localStorage.getItem("theme");
          if (stored === "light" || stored === "dark") return stored;
          return systemThemeQuery.matches ? "dark" : "light";
        }

        function syncFavicon() {
          const favicon = document.querySelector("link[data-theme-favicon]");
          if (!favicon) return;
          favicon.href =
            getCurrentTheme() === "dark" ? faviconDarkMode : faviconLightMode;
        }

        syncFavicon();
        document.addEventListener("astro:after-swap", syncFavicon);

        if (!window.__themeFaviconInitialized) {
          window.__themeFaviconInitialized = true;
          systemThemeQuery.addEventListener("change", syncFavicon);
          window.addEventListener("theme-changed", syncFavicon);
        }
      })();
    </script>
  )
}

{
  faviconScript === "rerun" && (
      <script is:inline data-astro-rerun>
      const systemThemeQuery = window.matchMedia(
        "(prefers-color-scheme: dark)",
      );
      const faviconLightMode = "/favicon-light-theme.png";
      const faviconDarkMode = "/favicon-dark-theme.png";

      const updateFaviconColor = (isDark) => {
        document.querySelector("link[data-theme-favicon]")?.remove();
        const link = document.createElement("link");
        link.rel = "icon";
        link.type = "image/png";
        link.setAttribute("data-theme-favicon", "");
        link.href = isDark ? faviconDarkMode : faviconLightMode;
        document.head.appendChild(link);
      };

      const sync = () => updateFaviconColor(systemThemeQuery.matches);

      document.addEventListener("astro:after-swap", sync, { once: true });
      sync();

      systemThemeQuery.addEventListener("change", () =>
        updateFaviconColor(systemThemeQuery.matches),
      );
    </script>
  )
}
