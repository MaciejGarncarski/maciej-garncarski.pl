{
   "extends": "astro/tsconfigs/strict",
   "compilerOptions": {
      "esModuleInterop": true,
      "paths": {
         "@/*": ["./src/*"],
         "@layouts/*": ["./src/layouts/*"],
         "@pages/*": ["./src/pages/*"],
         "@components/*": ["./src/components/*"],
         "@lib/*": ["./src/lib/*"],
         "@assets/*": ["./src/assets/*"]
      },
      "jsx": "react-jsx",
      "jsxImportSource": "react"
   },
   "include": [".astro/types.d.ts", "**/*"],
   "exclude": ["dist"]
}
